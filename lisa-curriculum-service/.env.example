# Local Spring profile
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL from ../docker-compose.yml
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/lisadb
SPRING_DATASOURCE_USERNAME=lisa
SPRING_DATASOURCE_PASSWORD=lisa_secret
DB_DRIVER=org.postgresql.Driver
SPRING_FLYWAY_ENABLED=true
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Keep local run independent from Redis unless you explicitly want it
SPRING_CACHE_TYPE=simple
REDIS_HOST=MISSING_REDIS_HOST
REDIS_PORT=MISSING_REDIS_PORT
REDIS_PASSWORD=

# DEV ONLY: copy from lisa-user-payment-service/ProjectLucy.API/appsettings.json
JWT_SECRET=MISSING_JWT_SECRET
JWT_ISSUER=ProjectLucy.API
JWT_AUDIENCE=ProjectLucy.Client
JWT_ROLE_CLAIM=http://schemas.microsoft.com/ws/2008/06/identity/claims/role
JWT_USER_ID_CLAIM=http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier
JWT_EMAIL_CLAIM=http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress

# Role IDs emitted by the current .NET access token
LMS_ROLE_ID_USER=1
LMS_ROLE_ID_MENTOR=2
LMS_ROLE_ID_CREATOR=3
LMS_ROLE_ID_ADMIN=4

# External services
USER_SERVICE_BASE_URL=MISSING_USER_SERVICE_BASE_URL
REALTIME_SERVICE_BASE_URL=http://localhost:3000
REALTIME_SOCKET_URL=http://localhost:3000
REALTIME_SESSION_JOIN_EVENT=session.join

# LMS session behavior
LMS_AUTO_SWITCH_SCAN_INTERVAL_MS=60000
LMS_END_SESSION_ON_LAST_SUBLEVEL=false

# Optional actuator tuning
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
